# ─────────────────────────────────────────────
# AXIOM Backend — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# AWS Bedrock (Orchestrator Brain)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-5-20251101-v1:0

# Groq (Sub-agent Inference)
GROQ_API_KEY=
GROQ_MODEL_ID=llama-3.3-70b-versatile

# Supabase (Persistent Memory + Auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Redis (Session Memory + Pub/Sub)
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# App
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://axiom.vercel.app

# Logging
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
